# Required
OCI_COMPARTMENT_ID=ocid1.compartment.oc1..xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OCI_REGION=us-phoenix-1

# Optional
LOG_LEVEL=INFO          # DEBUG | INFO | WARNING | ERROR
MCP_PORT=8000           # HTTP mode only
MCP_HOST=0.0.0.0        # HTTP mode only

# Telemetry — records tool call counts, latency, and error rates LOCALLY only.
# No data ever leaves your host. Set to "off" to disable entirely.
OCI_MCP_TELEMETRY=local           # local | off
OCI_MCP_METRICS_FILE=oci_mcp_metrics.jsonl  # path to metrics output file

# OCI config file (used when Instance Principal is unavailable, e.g. local dev)
# OCI_CONFIG_FILE=~/.oci/config
# OCI_CONFIG_PROFILE=DEFAULT
